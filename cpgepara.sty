\NewDocumentCommand\newsimplifiedtitle{mmmod()}{%
	\edef\title@name{\@xp\@gobble\string#1}%
	\begingroup%
	\def\@tmp{\endgroup\cpgedefcounter}
	\eappto\@tmp{{c\title@name}}
	\ifblank{#3}{\appto\@tmp{{|1|}}}{\appto\@tmp{{#3}}}
	\IfValueTF{#4}{\appto\@tmp{[#4]}}{\appto\@tmp{[section]}}
	\IfValueT{#5}{\appto\@tmp{(#5)}}
	\@tmp%
	\csdef{deco@c\title@name}{\commondeco\titlepunct}%
	\csdef{\title@name @title@setopts}{%
		\pgfqkeys{/cpge/customtitle}{s,i,bs,as,bf,#2}%
	}%
	\newrobustcmd#1{%
		\xdef\title@name{\@xp\@gobble\string#1}%
		\title@getargs%
	}%
}
\NewDocumentCommand\renewsimplifiedtitle{mmmod()}{%
	\edef\title@name{\@xp\@gobble\string#1}%
	\begingroup%
	\def\@tmp{\endgroup\cpgedefcounter}
	\eappto\@tmp{{c\title@name}}
	\ifblank{#3}{\appto\@tmp{{|1|}}}{\appto\@tmp{{#3}}}
	\IfValueTF{#4}{\appto\@tmp{[#4]}}{\appto\@tmp{[section]}}
	\IfValueT{#5}{\appto\@tmp{(#5)}}
	\@tmp%
	\csdef{deco@c\title@name}{\commondeco\titlepunct}%
	\csdef{\title@name @title@setopts}{%
		\pgfqkeys{/cpge/customtitle}{s,i,bs,as,bf,#2}%
	}%
	\renewrobustcmd#1{%
		\xdef\title@name{\@xp\@gobble\string#1}%
		\title@getargs%
	}%
}
\newsimplifiedtitle\customtitle{}{}
\DeclareDocumentCommand\title@getargs{d<>som}{%
	\gdef\title@cmd{\custom@title}%
	\IfValueT{#1}{\gappto\title@cmd{<#1>}}%
	\IfValueT{#3}{\gappto\title@cmd{[#3]}}%
	\gappto\title@cmd{{#4}}%
	\global\@incolfalse
	\global\@runinfalse%
	\ifb@columns%
		\IfBooleanT{#2}{\global\@incoltrue}%
		\if@incol%
			\title@cmd%
		\else%\show\thecolumn
			%\group@close
			\col[1][\title@cmd]%
		\fi%
	\else%
		\title@cmd%
	\fi%
}
\DeclareDocumentCommand\custom@title{d<>om}{%
	%\breakifnospace[\title@breakfacfrac]%
		\csuse{\title@name @title@setopts}%
		\IfValueT{#1}{\pgfqkeys{/cpge/customtitle}{#1}}%
		\IfValueTF{#2}
			{\boolfalse{@counterin}%
				\def\title@localnum{\csuse{deco@c\title@name}{#2}}%
				\ifblank{#2}{\def\title@localnum{}\let\cpge@enskip\relax}{}%
			}{%
				\booltrue{@counterin}%
				\ifdef\title@localnum{}%
					{\def\title@localnum{\usecounterstyle{c\title@name}}}%
			}%
		\ifb@span%
			\titlebeforeskip=\glueexpr\interskipamount*1/2\relax%
			\titleafterskip=\glueexpr\interskipamount*1/2\relax%
		\fi%
		\if@runin
			\cpge@startsection
				{\title@indent}
				{2\titlebeforeskip}
				{\title@runinsep}
				{\titlestyle\title@style}
				{#3}%
			\mbox{}%
		\else 
			\cpge@startsection
				{\title@indent}
				{2\titlebeforeskip}
				{\titleafterskip}
				{\titlestyle\title@style}
				{#3}%
		\fi%
		\ifbool{@counterin}{}%
			{\phantomsection%
				\protected@edef\@currentlabel{\title@localnum}}%
		\def\@currentabelname{#3}%
		\global\b@newcellfalse%
	%\endgroup%
}

