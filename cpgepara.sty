\newcommand*\cpgesetuppc{\pgfqkeys{/cpge/pc}}
\cpgesetup[pc]{rule/.is family, rule,% 
	b/.code=\dimdef\c@before@hrule{\dp\strutbox+#1},
	a/.code=\dimdef\c@after@hrule{\dp\strutbox+#1},
