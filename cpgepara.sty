%%% Commandes de fermeture des environnement de liste
%%% \closeall ferme récursivement TOUS les niveaux ouverts
%%% \closelist ferme le niveau courant s'il y'en a un
\newrobustcmd\closeall{%
	\iflistopen%
%		\ifhmode\strut\fi%
	\endlistcmd\endgroup%
	\@xp\closeall\fi%
}
