%%% \customtile, utilise le mécanisme Vanilla de LaTeX
%%% pour placer le titre, mais avec sa propre initialisation 
%%% des arguments
%%% desactive \<secion>mark et \addcontentsline

\def\cpge@startsection#1#2#3#4{%
	% #3=indent -> #1
	% #4=beforeskip -> #2,  si <0 => \noindent pour texte suivant 
	% #5=afterskip -> #3, si <0 mode runin
	% #6=style -> #4
  \if@noskipsec \leavevmode \fi
  \par
  \@tempskipa=\glueexpr #2\relax
  \@afterindenttrue
  \ifdim \@tempskipa <\z@
    \@tempskipa -\@tempskipa \@afterindentfalse
  \fi
  \if@nobreak
    \everypar{}%
  \else
    \addpenalty\@secpenalty
		\xaddvspace\@tempskipa
  \fi
   \cpge@sect{#1}{#2}{#3}{#4}%
}
\def\cpge@sect#1#2#3#4#5{%
	% #3=indent -> #1
	% #4=beforeskip -> #2,  si <0 => \noindent pour texte suivant 
	% #5=afterskip -> #3, si <0 mode runin 
	% #6=style -> #4
	% [#7]=alt title, deleted 
	% #8=title -> #5
  \protected@edef\@svsec{\cpge@seccntformat\relax}%
  \@tempskipa=\glueexpr #3\relax
  \ifdim \@tempskipa>\z@
    \begingroup
      #4{%
        \cpge@hangfrom{\hskip #1\relax\@svsec}%
          \interlinepenalty \@M #5\@@par}%
    \endgroup
  \else
    \def\@svsechd{%
      #4{\hskip #1{\@svsec}\ignorespaces #5}%
    }%
  \fi
  \cpge@xsect{#3}}
\def\cpge@xsect#1{%
  \@tempskipa=\glueexpr #1\relax
  \ifdim \@tempskipa>\z@
    \par \nobreak
	  \vskip \@tempskipa
    \@afterheading
  \else
    \@nobreakfalse
    \global\@noskipsectrue
    \everypar{%
      \if@noskipsec
        \global\@noskipsecfalse
       {\setbox\z@\lastbox}%
        \clubpenalty\@M
        \begingroup \@svsechd \endgroup
        \unskip
        \@tempskipa #1\relax
        \hskip -\@tempskipa
      \else
        \clubpenalty \@clubpenalty
        \everypar{}%
      \fi}%
  \fi
  \ignorespaces}
%\def@seccntformat#1{\csname label@#1\endcsname\enskip}
\def\cpge@seccntformat{\commondeco\title@localnum\cpge@enskip}
\def\cpge@hangfrom#1{\setbox\@tempboxa\hbox{{#1}}%
	\global\titlenumwidth=\wd\@tempboxa%
      \hangindent \titlenumwidth\noindent\box\@tempboxa}

