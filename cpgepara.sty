\def\head@text#1#2#3{%
	\setbox\@tempboxa\vtop{\color@begingroup\titlestyle\bfseries#3\color@endgroup}%
	\dimdef\cpge@tempa{\ht\@tempboxa+#1}%
	\setbox\@tempboxa\vbox{\color@begingroup\titlestyle\bfseries#3\color@endgroup}%
	\dimdef\cpge@tempb{\dp\@tempboxa+#2}%
	\nointerlineskip
	\vskip-\parskip%
	\vrule 	height\dimexpr\cpge@tempa
			width\z@% 
	\nobreak\color@begingroup\titlestyle\bfseries#3\color@endgroup%
	\nobreak\vrule	depth\dimexpr\cpge@tempb
					width\z@%
	\vspace*{-\dimexpr\baselineskip}
}

\NewDocumentCommand\pcrule{d<>}{%
	\groupclose%
	\begingroup%
		\IfValueT{#1}{\pgfqkeys{/cpge/pc/rule}{#1}}%
		\switchcolumn[0]*%
		\nointerlineskip%
		\vspace{-\interskipamount}
		\vspace{\c@before@hrule+1sp-1\parskip}
		\columns@rule\rule@height{single@rule}%
		\nointerlineskip
		\vspace{\c@after@hrule+1sp-1\parskip}%
	\endgroup%
	\bprogram%
}

%% ouvre un groupe et place un jeton, ferme le groupe
\NewDocumentCommand\groupopen{m}{%
	\begingroup\booltrue{group@b@open}%
	\killparskip%
	\ignorespaces%
	\global\b@newcelltrue%
	\everypar{\global\b@newcellfalse\everypar{}}%
	\csuse{#1@align}\csuse{#1@style}%
}
\NewDocumentCommand\groupclose{s}{%
	\closeall%
	\ifgroup@b@open%
		\par
		\unless\ifb@newcell%
			\IfBooleanF{#1}{\normal@vskip{\interskipamount}}%
		\fi%
		\endgroup%
	\fi%
}
\def\group@close{%
	\closeall%
	\ifgroup@b@open\endgroup\@xp\group@close\fi%
}

