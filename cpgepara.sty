		{\ifcsdef{cw@#1}
			{%
				\def\widths@{}%
				\ifnumless{#1}{\leftcolnumber}
					{\eappto\cols@widthslist{\csname cw@#1\endcsname,}}
					{\eappto\leftcols@widthslist{\csname cw@#1\endcsname,}}
			}
			{\ifnumless{#1}{\leftcolnumber}
				{\appto\cols@widthslist{,}}
				{\appto\leftcols@widthslist{,}}
			}
		}
		{\ifcsdef{cw@#1}
			{%
