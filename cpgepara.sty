\def\columnskillspace{%
	\begingroup
	\edef\@tmp{\endgroup%
		\@nx\setlist[itemize]{\@xo\opts@itemize@columns}%
		\@nx\setlist[enumerate]{\@xo\opts@enumerate@columns}%
	}%
	\@tmp
