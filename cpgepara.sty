}

\def\tabkilllistspaces{%
	\setlist*{labelsep=.45em, nosep, topsep=-\baselineskip, partopsep=-\parskip}
	\appto\endlist\shrink@it
	}
\def\shrink@it{\vskip\z@skip}
\def\killparskip{\cpgesetparskip{\z@skip}}
\def\cpgesetparskip#1{%
	\setlength{\parskip}{#1}\parsep\parskip}
\NewDocumentCommand\breakifnospace{O{2}}{%
	\cpge@dima=#1\baselineskip\relax%
	\cpge@dimb=\pagegoal \advance\cpge@dimb-\pagetotal%
	\ifbool{b@columns}
		{\ensurevspace{#1\baselineskip}}
		{\ifdim\cpge@dimb<\cpge@dima\raggedbottom\eject\fi}%
}

\newcount\cpge@pena	
\newcount\cpge@penb
\newcommand\cpgesetpen[2]{%
	\cpge@pena=\numexpr#1\relax%
	\cpge@penb=\numexpr#2\relax%
}
\cpgesetpen{601}{1001}
\def\cpge@no@pgbk #1#2{%
  \ifvmode
    \penalty #1\cpge@getpen{#2}%
  \else
    \@bsphack
    \vadjust{\penalty #1\cpge@getpen{#2}}%
    \@esphack
  \fi}
\def\cpge@getpen#1{\ifcase #1 \z@ \or \@lowpenalty\or
  \@medpenalty \or  \@highpenalty \or \cpge@pena \or \cpge@penb \else \@M \fi}
\def\alt@break#1{\cpge@no@pgbk-{#1}}
\def\alt@nobreak#1{\cpge@no@pgbk{}{#1}}
\NewDocumentCommand\altbreak{o}{%
	\ifbool{b@columns}%
		{%
			\IfValueTF{#1}%
				{\col[1]*[\alt@break{#1}]}%
				{\col[1]*[\alt@break{6}]}%
		}{%
			\IfValueTF{#1}%
				{\alt@break{#1}}%
				{\alt@break{6}}%
		}%
}
\NewDocumentCommand\altnobreak{o}{%
	\ifbool{b@columns}%
		{%
			\IfValueTF{#1}%
				{\col[1]*[\alt@nobreak{#1}]}%
				{\col[1]*[\alt@nobreak{6}]}%
		}{%
			\IfValueTF{#1}%
				{\alt@nobreak{#1}}%
				{\alt@nobreak{6}}%
		}%
}


