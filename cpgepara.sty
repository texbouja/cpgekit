			{\ifnum\numexpr\pgfkeyscurrentname>\maxcolnumber
				\maxcolnumber@err{\pgfkeyscurrentname}
			\else 
				\colbackcol<#1>{\pgfkeyscurrentname}
			\fi} 
			{\common@err{\string\setbackcol\space option		
					\pgfkeyscurrentname\space inconnue}}
		},
	reset/.code=\resetbackgroundcolor,
	default/.code=\processdefaultbackcol,
}
\newrobustcmd*\cpgesetupbackground[1]{%
	\global\global@colorstrue%
	\ifundef\colnumber{\numdef\colnumber{\maxcolnumber}}{}%
	\pgfqkeys{/cpge/backcol}{#1}%
}
\NewDocumentCommand\setbackcol{mmo}{%
	\begingroup%
		\pgfqkeys{/cpge/backcol/.hidden}{#1}
		\ifundef\backcol@col
			{\let\backcol@name\backcol@type
			  \edef\backcol@cmd{\backcol@type}}
			{\edef\backcol@name{\backcol@type\backcol@col}
				\edef\backcol@cmd{\backcol@type[\backcol@col]}}
		\IfValueTF{#3}
			{\xcolorlet{\backcol@name backcolor}{#3}
			  \pgfqkeys{/cpge/backcol/keys}{#2}}
			{\pgfqkeys{/cpge/backcol/keys}{c=defaultbackgroundcolor,#2}}%
		\process@backcolkeys%
		\preto\backcol@cmd{\backgroundcolor}
		\backcol@cmd%
	\endgroup%
}
\NewDocumentCommand\colbackcol{D<>{}sm}{%
	\IfBooleanTF{#2}
		{\dimdef\tmp@xshift{\commonxshift}}
		{\dimdef\tmp@xshift{\xshift}}
	\ifnum\numexpr#3=1\relax
		\setbackcol{t=c,n=1}{l=\commonxshift,r=\tmp@xshift,#1}[oddcol]
	\else
		\ifnum\numexpr#3<\numexpr\colnumber\relax
			\ifodd\numexpr#3\relax
				\setbackcol{t=c,n=#3}{h=\tmp@xshift,#1}[oddcol]
			\else 
				\setbackcol{t=c,n=#3}{h=\tmp@xshift,#1}[evencol]
			\fi 
		\else 
			\ifodd\numexpr#3\relax
				\setbackcol{t=c,n=#3}
					{r=\commonxshift,l=\tmp@xshift,#1}[oddcol]
			\else 
				\setbackcol{t=c,n=#3}
					{r=\commonxshift,l=\tmp@xshift,#1}[evencol]
			\fi 
		\fi
	\fi
}
\def\xcolorlet{%
	\ifbool{global@colors}%
		{\def\@reserveda{\xglobal\colorlet}}
		{\def\@reserveda{\colorlet}}%
	\@expandtwoargs\@reserveda
}

\def\process@backcolkeys{
	\eappto\backcol@cmd{(\xl@shift,\yt@shift)(\xr@shift,\yb@shift)}
	\xdef\backcol@cmd{{\@xo\backcol@cmd}{\backcol@name backcolor}}
}

\def\processdefaultbackcol{%
	\begingroup%
		\setbackcol{t=s}{v=-1pt,h=\commonxshift}[spancol]%
		\def\do##1{\colbackcol{##1+1}}%
		\dolistloop\columnlist%
	\endgroup%
}


