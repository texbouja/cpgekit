%% liste utilisée ensuite pour boucles dans d'autres clés
\long\def\create@columnlist{%
	\ifnum\col@count<\colnumber\relax%
		\listeadd\columnlist{\the\col@count}%
		\advance\col@count\@ne%
		\@xp\create@columnlist%
	\fi%
}
