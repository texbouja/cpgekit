%% Commande générique qui teste que le nom de la clé dans 
%% numcol= est bien un entier inférieur à \colnumber
%% retourne son arg si vrai et déclenche une erreur si faux.
\def\numkey@process#1{%
	\cpge@isnumber{\pgfkeyscurrentname}
		{
			\ifnum\numexpr\pgfkeyscurrentname>\numexpr\colnumber
				\numkey@err 
			\else 
				#1%
			\fi%
		}{\numkey@err}
}
