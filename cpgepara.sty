\DeclareDocumentCommand\init@pc{!d<> +o}{%
		\IfValueT{#1}{\pgfkeys{/cpge/pc/save to current/.list={#1}}}
		\begingroup 
			\booltrue{b@span}%
			\IfValueT{#1}{
				\pgfqkeys{/cpge/pc}{#1}
			}%
			\IfValueTF{#2}{\open@pc[#2]}{\open@pc}%
}
\DeclareDocumentCommand\open@pc{ +o}{%
	\booltrue{b@columns}%
	\pc@beforehook%
	\columnskillspace%
	\def\colnumber{2}%
	\def\columnlist{0,1}%
	\renewrobustcmd\bcolumn{\nrfalse\init@cell\columns@cell}%
	\newrobustcmd\col{\nrfalse\init@cell\columns@cell}%
    \renewrobustcmd\interskip[1]{%
        \groupclose\init@cell\columns@cell[\thecol][\normal@vskip{##1}]
	}
	\process@columnwidths%
	\ifdef\widths@
		{\@xp\setcolumnwidth\@xp{\cols@widthslist}}
		{\ifdef\left@ratio
			{\@xp\columnratio\@xp{\left@ratio}}
			{\columnratio{}}%
		}%
	\def\interrule{\pcrule}%
	\vskip\pc@beforeskip%
	\IfValueTF{#1}{\paracol{2}[#1]}{\paracol{2}}%
}
\NewDocumentCommand\bprogram{!d<> +o}{%
	\groupclose%
	\ifb@columns
		\IfValueTF{#2}
			{\switchcolumn[0]*[\b@columnsfalse#2]}
			{\switchcolumn[0]*}%
	\else
		\init@pc<#1>%
		\ifbool{b@head}{\pc@head}{}%
		\IfValueTF{#2}
			{\switchcolumn[0]*[\b@columnsfalse#2]}
			{\switchcolumn[0]*}%
	\fi 
	\ifb@markallparacom%
		\global\stepcounter{paracom}\print@numparacom%
	\fi%
	\gdef\thecol{1}%
	\groupopen{0}%
		%\csuse{0@style}\csuse{0@align}%
}
\NewDocumentCommand\bcomment{!d<> +o}{%
	\groupclose%
	\ifb@columns
		\IfValueTF{#2}
			{\switchcolumn[1]*[\b@columnsfalse#2]}
			{\switchcolumn[1]}
	\else	
		\bprogram<#1>[#2]
		\groupclose
		\switchcolumn[1]
	\fi
	\gdef\thecol{2}%
	 \groupopen{1}%
}
\NewDocumentCommand\nbprogram{!d<> +o}{%
	\bprogram<#1>[#2]%
	\unless\ifb@markallparacom%
		  \refstepcounter{paracom}\print@numparacom%
	\fi%
}
\def\pc@head{%
	\groupclose*
	\ensurevspace{4\baselineskip}%
	\columns@rule\top@ruleheadheight{head@rule}
		\head@text\innertop@headspace\innerbottom@headspace{\left@head}
	\switchcolumn[1]%
		\head@text\innertop@headspace\innerbottom@headspace{\right@head}
	\columns@rule\bottom@ruleheadheight{head@rule}
	\nointerlineskip%
	\vspace*{\glueexpr\outerbottom@headspace+1sp-\parskip}%
	\switchcolumn[0]*
	\groupopen{0}%
}
