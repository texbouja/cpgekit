	seprule color/.code=\colseprulecolor{#1}, 
	seprule/.style 2 args={seprule width=#1, seprule color=#2},
	before/.store in=\pc@beforehook, before={},
	after/.store in=\pc@afterhook, after={},
	beforeskip/.code=\cpge@gluedef\pc@beforeskip{#1}\medskipamount,
	afterskip/.code=\cpge@gluedef\pc@afterskip{#1}\medskipamount,
%%% alignement du texte dans les colonnes 
	left align/.is choice,
	left align/l/.code=\csdef{0@align}{\RaggedRight},
	left align/c/.code=\csdef{0@align}{\Centering},
	left align/r/.code=\csdef{0@align}{\RaggedLeft},
	right align/.is choice,
	right align/l/.code=\csdef{1@align}{\RaggedRight},
	right align/c/.code=\csdef{1@align}{\Centering},
	right align/r/.code=\csdef{1@align}{\RaggedLeft},
	align/.code 2 args=
		\ifblank{#1}{}{\pgfkeysalso{left align=#1}}
		\ifblank{#2}{}{\pgfkeysalso{right align=#2}},
	left style/.code=\csdef{0@style}{#1},
	right style/.code=\csdef{1@style}{#1},
	backcol/.code=\pgfqkeys{/cpge/backcol}{default, #1},
	backcol/.default={},
	backcol*/.code=\global\global@colorstrue
		\pgfqkeys{/cpge/backcol}{default, #1},
	backcol*/.default={},
	interrule/.code=\pgfqkeys{/cpge/pc/rule}{#1},
%%%% head specific options 
	headrules width/.code 2 args=\dimdef\top@ruleheadheight{#1}\dimdef\bottom@ruleheadheight{#2}, 
	headrules color/.code=\colorlet{head@rule}{#1},
	headrules/.style n args={3}{headrules width={#1}{#2},headrules color={#3}},
	tophead/.code=\dimdef\innertop@headspace{\ifblank{#1}{\ht\strutbox+2pt}{\ht\strutbox+2pt+#1}},
