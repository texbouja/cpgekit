%% récupère le nbre de colonne et lance \open@columns
\DeclareDocumentCommand\init@columns{om d<> +o}{%
	\ifnumgreater{#2}{\maxcolnumber}
		{\pgfkeyscurrentname{#2}}
		{%
			\IfValueT{#3}
				{\pgfkeys{/cpge/columns/save to current/.list={#3}}}
			\begingroup %
			\booltrue{b@span}%
			\IfValueT{#1}{%
				\def\leftcolnumber{#1}%
			}%
			\def\colnumber{#2}%
			\setcolumnlist%
			\IfValueT{#3}{\pgfqkeys{/cpge/columns}{#3}}%
			\open@columns[#4]
		}%
}
%% definit les commandes de deplacement et applique les options
\DeclareDocumentCommand\open@columns{+o}{%
	\booltrue{b@columns}%
	\newrobustcmd\col{\nrfalse\init@cell\columns@cell}%
	\columns@literalnames%
	\renewrobustcmd\interskip[1]{%
        \groupclose\init@cell\columns@cell[\thecol][\normal@vskip{##1}]%
	}
	\RenewDocumentCommand\interrule{d<>}{%
		\groupclose\init@cell\columns@cell[1][\columns@fullrule<##1>]%
	}%
	\process@columnwidths%
	\ifundef\widths@%%
		{\ifdef\cols@ratio
			{\@xp\columnratio\@xp{\cols@ratio}}
			{\columnratio{}}%
		}{%
			\ifdef\leftcolnumber
				{\edef\@tmp{%
					\@nx\setcolumnwidth{\cols@widthslist}	
						[\leftcols@widthslist]}
				}
				{\edef\@tmp{\@nx\setcolumnwidth{\cols@widthslist}}}
			\@tmp%
		}
	\renewrobustcmd\bcolumn{\nrfalse\init@cell\columns@cell}%
	\columns@beforehook%
	\columnskillspace%
	\ifhmode\@@par\fi\addvspace\cols@beforeskip%
	\ifdef\leftcolnumber
		{\IfValueTF{#1}%
			{\edef\cpge@tmp{%
				\noexpand\paracol[\leftcolnumber]*{\colnumber}[#1]}}%
			{\edef\cpge@tmp{%
				\noexpand\paracol[\leftcolnumber]*{\colnumber}}}}
		{\IfValueTF{#1}%
			{\edef\cpge@tmp{%
				\noexpand\paracol{\colnumber}[#1]}}%
			{\edef\cpge@tmp{%
				\noexpand\paracol{\colnumber}}}}%
	\cpge@tmp%
}
%% commande qui ouvre l'environnement  
\DeclareDocumentCommand\columns@firstcmd{om!d<>!O{1}!s!+o}{%open@colum
	\cpge@isnumber{#2}%
		{\init@columns[#1]{#2}<#3>[#6]}%
		{\common@err{
			\string\bcolumn\space: nombre de colonnes non fourni}}%
	\ifbool{b@head}{\columns@head{\bcolumn[#4]*}}{\bcolumn[#4]}%
}
%% au départ \bcolumn est \columns@firstcmd, 
%% elle est redéfinie par \open@columns
\newrobustcmd\bcolumn{\columns@firstcmd}
\DeclareDocumentCommand\cycle@cell{o}{%
    \IfValueTF{#1}{%
    	\if@plusatbegin{#1}%
			{\numdef\cols@to{\thecolumn+\cpge@arg}}%
			{\numdef\cols@to{\cpge@arg-1}}%
		}{%
			\numdef\cols@to{\thecolumn+1}%
			\ifnum\numexpr\cols@to=\numexpr\colnumber\relax%
				\def\cols@to{0}\b@nextrowtrue%
			\fi%
        }%
    \unless\ifnum\numexpr\cols@to<\numexpr\colnumber%
        \numdef\cols@to{\numexpr\cols@to-\colnumber}%
    \fi%
	\numgdef\thecol{\cols@to+1}%
}
%% collecte les arguments d'une commande bcolumn/col dans l'environnement
\DeclareDocumentCommand\init@cell{m!d<>!o!s!+o}{%
	\IfValueT{#2}{\pgfqkeys{/cpge/columns/interrule}{#2}}%
    \def\cmd@cell{\switchcolumn}%
    \cycle@cell[#3]%
    \eappto\cmd@cell{[\cols@to]}%
    \IfBooleanT{#4}{\b@nextrowtrue}%
    \IfValueT{#5}{\b@nextrowtrue}%
    \ifbool{b@nextrow}{\appto\cmd@cell{*}}{}%
    \IfValueT{#5}{%
		\appto\cmd@cell{%
			[\boolfalse{b@columns}#5]%
			\booltrue{b@columns}%
		}%
	}%
	#1%
}
%% lance la commande formée par \init@cell avec les arguments collectés
\long\def\columns@cell{%
		\cmd@cell\groupopen{\thecolumn}%
}%
%% insère l'entête. 
\long\def\columns@head#1{%
	\ensurevspace{4\baselineskip}%
	\columns@rule\top@ruleheadheight{head@rule}%
	\forlistloop\columns@loophead\columnlist%
	\groupclose*%
	\columns@rule\bottom@ruleheadheight{head@rule}%
	\nointerlineskip%
	\vspace*{\glueexpr\outerbottom@headspace+1sp-\parskip}%
	#1%
}
%% commande autonome pour insérer un entête
\NewDocumentCommand\colhead{d<>m}{%
	\ifbool{b@columns}
		{\ensurevspace{4\baselineskip}%
		\group@close%
		\IfValueTF{#1}
			{\pgfqkeys{/cpge/columns}{col head={b,#2}, #1}}
			{\pgfqkeys{/cpge/columns}{col head={b,#2}}}%
		\columns@rule\top@ruleheadheight{head@rule}%
		\forlistloop\columns@loophead\columnlist%
		\groupclose*%
		\columns@rule\bottom@ruleheadheight{head@rule}%
		\nointerlineskip%
		\vspace*{\glueexpr\outerbottom@headspace+1sp-\parskip}%
		\col[1]*}
		{\common@err{\string\colhead\space: l'environnement multicolonne n'est pas ouvert}}%
}
\newrobustcmd\colheadrules[1]{
	\ensurevspace{4\baselineskip}%
	\columns@rule\top@ruleheadheight{head@rule}%
	#1%
	\groupclose*%
	\columns@rule\bottom@ruleheadheight{head@rule}%
	\nointerlineskip%
	\vspace*{\glueexpr\outerbottom@headspace+1sp-\parskip}%
	\col[1]*%
}
%% boucle qui insère les entrées de l'entète par colonne
\def\columns@loophead#1{%
	\columns@headtext\innertop@headspace\innerbottom@headspace
		{\csuse{\thecolumn @head}}
	\unless\ifnum\numexpr#1=\numexpr\colnumber-1\relax%
		\groupclose*\@xp\bcolumn%
	\fi%
}
%% placement des entrées de l'entête avec espaces vert avant et après
\def\columns@headtext#1#2#3{%
	\setbox\@tempboxa\vtop{\color@begingroup\titlestyle\bfseries#3\color@endgroup}%
	\dimdef\cpge@tempa{\ht\@tempboxa+#1}%
	\setbox\@tempboxa\vbox{\color@begingroup\titlestyle\bfseries#3\color@endgroup}%
	\dimdef\cpge@tempb{\dp\@tempboxa+#2}%
	\color@begingroup\csuse{\thecolumn @headalign}%
	\nointerlineskip
	\vskip-\parskip%
	\vrule 	height\dimexpr\cpge@tempa
			width\z@% 
	\nobreak\titlestyle\bfseries#3%
	\nobreak\vrule	depth\dimexpr\cpge@tempb
					width\z@%
	\color@endgroup%
}
% commande interne d'insertion de ligne de séparation 
\DeclareDocumentCommand\columns@fullrule{d<>}{%
	\begingroup 
		\IfValueT{#1}{\pgfqkeys{/cpge/columns/interrule}{#1}}%
		\normal@vskip{-\interskipamount}%
		\vspace{\c@before@hrule+1sp-1\parskip}%
		\columns@rule\rule@height{single@rule}%
		\nointerlineskip%
		\vspace{\c@after@hrule+1sp-1\parskip}%
	\endgroup%
}
%% ligne de séparation sans les espaces
\def\columns@rule#1#2{%
	\switchcolumn[0]*[%
		\color@begingroup%
			\color{#2}%
			\hrule height#1 width\textwidth\relax%
		\color@endgroup%
	]%
}
%% ligne de cloture de l'environnement
\def\final@rule{%
	\group@close%
	\switchcolumn[0]*
	\normal@vskip{-\interskipamount}%
	\vspace{\outerbottom@headspace+1sp}%
	\columns@rule\top@ruleheadheight{head@rule}%
}
%% saut vertical normal gérant la syntaxe *...
\def\normal@vskip#1{%
	\nointerlineskip%
	\cpge@assign\cpge@skipa#1\relax\outerparskip%
	\vspace{\cpge@skipa}%
}
\newcommand\interskip{%
	\common@err{\string\interskip ne fonctionne pas
	 en dehors du mode multicolonne}
}
\newcommand*\ecolumn{%
	\groupclose%
	\ifbool{b@columns}{%
		\ifbool{b@head}{\final@rule}{}%
		\endparacol%
		\unless\ifglobal@colors\resetbackgroundcolor\fi%
		\columns@afterhook%
	  	 \vskip\cols@afterskip%
		   \endgroup}{}%
}

\NewDocumentCommand\colspan{+m}{%
