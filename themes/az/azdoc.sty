\tikzset{proof title style/.style={
	rounded corners=6pt,
	inner xsep=8pt,
	fill=none,
	draw=linkstrokecol, 
	text=linktextcol
}}

%%% Style des titres 
\titleformat{\part}[display]{}
	{\begin{tikzpicture} [overlay]\node at (.5\textwidth-\marginparwidth,.2\textheight) {\pgfuseimage{chart}};\end{tikzpicture}}
	{\z@skip}
	{\filleft\fontsize{48}{48}\HeadingFont\color{titletextcol}#1}
	[{\begin{tikzpicture}[overlay]\node  at (-\right@margin,-.4\paperheight) [anchor=east, opacity=.75] {\pgfuseimage{tree}};\end{tikzpicture}}]

\cpgesetlabel{chapter}{|1|}
\titleformat{\chapter}[display]
	{\firaheavy\fontsize{36}{36}\color{titletextcol}}
	{%
		\begin{tikzpicture} [overlay, remember picture, baseline=(C.base)] 
			\node (C) at (30pt,0) [trapezium, trapezium left angle=120, trapezium right angle=60,
				fill=titletextcol, 
				text=white,
				text width=40pt,
				align=center,
				font=\fontsize{36}{36}\selectfont,
			]{\label@chapter};
			\node [cpgered] at ([yshift=10pt] C.north) 
				{\Large\chaptername}; 
		\end{tikzpicture}
	}{6pt}
	{\filleft\begin{tikzpicture} [remember picture]
		\node (T)  [
			text width=\textwidth-2.5cm, 
			align=flush right,
			inner sep=0pt
			]
		{\filleft #1};\end{tikzpicture}\\
	\begin{tikzpicture} [overlay, remember picture]
		\draw [cpgered,  line width=12pt, line join=miter]
			([yshift=-2.5cm]T.south west) -- ([yshift=-12pt]C.south) -- +(-6cm,-4cm)
			([yshift=-2.5cm+6pt]T.south west) -- +(\paperwidth,1cm);\end{tikzpicture}
	}
\titleformat{name=\chapter, numberless}[display]
	{\fontsize{36}{36}\HeadingFont\color{titletextcol}}
	{\begin{tikzpicture}[overlay, remember picture]\coordinate (C);\end{tikzpicture}}
	{\z@skip}
	{\filleft\begin{tikzpicture} [remember picture]
		\node (T)  [
			text width=\textwidth-2.5cm, 
			align=right,
			inner sep=0pt
			]
		{\filleft #1};\end{tikzpicture}\\
	\begin{tikzpicture} [overlay, remember picture]
		\draw [cpgered,  line width=12pt, line join=miter]
			([yshift=-2.5cm]T.south west) -- ([yshift=-12pt]C.south) -- +(-6cm,-4cm)
			([yshift=-2.5cm+6pt]T.south west) -- +(\paperwidth,1cm);\end{tikzpicture}
	}
\titlespacing\chapter{0pt}{-\head@height+1pc}{3.5cm}

\cpgesetlabel{section}{|1|}
\cpgesetlabel{subsection}{|S|.|1|}
\titleformat{\section}[display]
	{\HeadingFont\LARGE\color{titletextcol}}
	{\begin{tikzpicture} [baseline=(S.base)] 
		\node (S)  [
			trapezium, 
			trapezium left angle=90, 
			trapezium right angle=-60,
			fill=cpgered, 
			text=white,
			text width=4pc,
			align=left,
			font=\HeadingFont\relsize{-2},
			anchor=center,
		]{\label@section};%
		\draw [cpgered, line width=.8pt]
		let \p0=(S.east) in   
			(\x0+.5pc,\y0) -- (\columnwidth - \x0 + .5pc +4pt,\y0); 
		\end{tikzpicture}%
	}
	{-0.9ex}
	{\filleft\parbox{\columnwidth-4.5pc}{\filleft #1}}
\titleformat{name=\section,numberless}[display]
	{\HeadingFont\LARGE\color{titletextcol}}
	{\begin{tikzpicture} [overlay]
	 \draw [cpgered, {Z[height=6pt, gap=1pc]}-, line width=.8pt] 
			(0,0) -- +(\columnwidth,0) ;
			\end{tikzpicture}%
	}
	{-3pt}
	{\filleft\parbox{\columnwidth-4.5pc}{\filleft #1}}
\titlespacing{\section}{-4pt}{*6}{*4}

\titleformat{\subsection}[hang]
	{\HeadingFont\Large\color{titletextcol}}
	{\begin{tikzpicture} [baseline=(S.base)] 
		\node (S) [trapezium, trapezium left angle=90, trapezium right angle=60,
				fill=cpgered, 
			text=white,
			align=left,
			text width=2.4pc,
			font=\relsize{-2},
			% anchor=east,
		]{\label@subsection};%
	\end{tikzpicture}}
	{.5em}
	{\filright #1}
\titleformat{name=\subsection,numberless}[hang]
	{\HeadingFont\Large\color{titletextcol}}
	{}
	{\z@}
	{\filright #1}
\titlespacing{\subsection}{-4pt}{*4}{*2}
\titleformat{\subsubsection}[hang]
	{\HeadingFont\large\color{titletextcol}}
	{\textcolor{cpgered}{\label@subsection}}
	{1pc}
	{\filright #1}
\titleformat{name=\subsubsection,numberless}[hang]
	{\HeadingFont\large\color{titletextcol}}
	{}
	{\z@}
	{\filright #1}

\titleformat{\paragraph}[runin]
	{\bfseries\scshape\color{titletextcol}}
	{}
	{\z@}
	{\filright #1}
\titleformat{name=\paragraph,numberless}[runin]
	{\bfseries\scshape\color{titletextcol}}
	{}
	{\z@}
	{\filright #1}
\titlespacing{\paragraph}{\z@}{\smallskipamount}{.5em}



