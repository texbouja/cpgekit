%%%% Tete et pied de page
\let\az@head\relax%
\let\az@foot\relax%

\dimdef\head@rgap{\Gm@rmargin}
\dimdef\head@lgap{\Gm@lmargin}

\def\prepare@foot{%
\def\az@foot{%
\ifodd\c@page%
	\begin{tikzpicture}[overlay]%
			\draw  [strokecol, {Z[gap=\head@lgap, height=6pt]}-] 
			(-\head@lgap,10pt) -- (3pc,10pt ) node  
		[text opacity=.5, fill=pagecol, font=\fontsize{6}{6}\firalight, anchor=west] 
		{\MakeLowercase{\cpge@centre@format}} -- (\paperwidth-\head@lgap,10pt);
	\end{tikzpicture}%
\else
	\begin{tikzpicture}[overlay]%
			\draw  [strokecol, -{Z[angle=-70,gap=\head@lgap, height=-6pt]}] 
			(-\head@rgap,10pt) -- (\textwidth-3pc, 10pt) node  
		[text opacity=.5, fill=pagecol, font=\fontsize{6}{6}\firalight, anchor=east]  
		{\MakeLowercase{\cpge@centre@format}} -- (\paperwidth-\head@rgap,10pt);
	\end{tikzpicture}%
\fi}
}
\def\prepare@head{%
	\def\az@head{%
	\ifodd\c@page%
		\begin{tikzpicture}[overlay]%
			\draw  [strokecol, -{Z[angle=-70,gap=\head@rgap, height=-3pt]}] 
			(-\head@lgap,-8pt) -- (\paperwidth-\head@lgap,-8pt);
		\end{tikzpicture}%
	\else
		\begin{tikzpicture}[overlay]%
			\draw  [strokecol, {Z[gap=\head@rgap, height=3pt]}-] 
			(-\head@rgap,-8pt) -- (\paperwidth-\head@rgap,-8pt);
		\end{tikzpicture}%
	\fi}%
}

\renewpagestyle{main}[\smaller\firalight\scshape\itshape]{%
		\renewcommand\makeheadrule{\az@head}%
		\renewcommand\makefootrule{\az@foot}%
		\def\foot@font{\color{textcol}\MakeLowercase}
		\def\head@font{\color{frametextcol}\MakeLowercase}
		\cpgesethead[|document|][][|theme|]
			(|theme|)()(|document|)%
		\cpgesetfoot[|classe|][][|page|]
			(|page|)()(|centre|)%
	}
\renewpagestyle{plain}[\smaller\firalight\scshape\itshape]{%
		\renewcommand\makefootrule{}%
		\sethead{}{}{}%
		\setfoot{}{\thepage}{}%
	}%
\AtBeginDocument{
	\ifdefstring{\cpge@currentclass}{note}{}{\prepare@head\prepare@foot}
	\def\deco@formula#1{%
		\tikz[baseline, anchor=base]\node[azline, fill=thmcol!15!pagecol, draw=thmcol, text=thmcol!35!textcol] {#1};%
	}
	\let\deco@result\deco@formula
}

%%% environnement mini
\def\az@mini#1{%
	\ifinsidemini%
		\textcolor{thmcol}{\strut#1}%
	\else
		\begin{tikzpicture} [remember picture, baseline=(M.base)] \node (M) [inner sep=\z@, text=thmcol] {\strut#1};
		\end{tikzpicture}
		\begin{tikzpicture} [overlay, remember picture]\draw [thmcol, {Z[height=3pt, width=1pc, angle=-70, gap=1pc]}-] 
		([xshift=-2pc, yshift=3pt]M.north west) -- 
		+(.66\textwidth,0);%
		\end{tikzpicture}
	\fi%
}

\cpgesetup[mini]{%
	before skip=\medskipamount,
	left margin=2pc,
	label font=\TitlingFont,
	font=\sffamily\relsize{-1},
	deco=\az@mini{#1}%
}
