\newdimen\titlewidth
\AtBeginDocument{
	\titlewidth=.8\paperwidth%
	\dimdef\head@height{\headsep+\headheight}%
	\dimdef\left@margin{\Gm@lmargin}%
	\dimdef\right@margin{\Gm@rmargin}%
	\dimdef\cover@margin{.15\paperwidth}
	\cpgesetup[title]{width=\titlewidth}
}
\def\setcover@back{%
	\def\cover@back{%
		\cpgesetcolormodel1%
		\pagecolor{mainthree}%
		\firabook%
		\begin{tikzpicture} [overlay, remember picture]
		\node  at (0,-.95\paperheight) [opacity=.5] {\pgfuseimage{tree}};
		\node (banner) at (\paperwidth-\cover@margin*1/2,-3cm) 
			[anchor=east, inner sep=0] 
			{\pgfuseimage{banner}};
		\node at ([xshift=\cover@margin*1/2, yshift=-.05\paperheight]banner.south east)   [anchor=east] {\pgfuseimage{chart}};
		\end{tikzpicture}%
}}
\NewDocumentEnvironment{az@title@page}{}{%
	\cover@back%
	\firabook%
	\setbox\@tempboxa\vbox\bgroup%
		\hsize\dimexpr\paperwidth-\cover@margin%
		\fil@inner@titlepage%
		\color{cpgered}\ignorespaces%
	}{\egroup%
		\ifdim\ht\@tempboxa<.36\textheight\relax%
			\setbox\@tempboxa\vbox to.36\textheight{\unvbox\@tempboxa}
		\fi%
	\null\vskip.25\paperheight\vfill%
	\hskip1pc
	\begin{tikzpicture}
		\node  (TITLE)
			[inner xsep =1.5pc, inner ysep=2pc]
		{\box\@tempboxa};
	\end{tikzpicture}
	\kern1pc\vfill%
}

\cpgesetup[title]{%
	early before*=\newgeometry{hmargin=\z@, vmargin=\z@},
	%late after*=\restoregeometry,
	before* =	\setcover@back%
				\begin{az@title@page},
	after*	=	\end{az@title@page},
	inner align*=r,
	outer align*=l 
}

