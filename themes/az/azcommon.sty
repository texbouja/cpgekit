\pgfkeys{
  /pgf/arrow keys/gap/.store in    = \ZGap,
  /pgf/arrow keys/gap              = 0pt,
  /pgf/arrow keys/height/.store in = \ZHeight,
  /pgf/arrow keys/height           = 10pt,
  /pgf/arrow keys/angle/.store in  = \ZAngle,
  /pgf/arrow keys/angle            = 70,
  /pgf/arrow keys/width/.store in  = \ZWidth,
  /pgf/arrow keys/width            = 12pt,
}

\pgfdeclarearrow{
  name = Z,
  parameters = { \ZGap, \ZHeight, \ZAngle, \ZWidth },
  setup code = {
    \pgfmathparse{\ZGap   / 1pt}\let\Ipt\pgfmathresult
    \pgfmathparse{\ZHeight / 1pt}\let\Hpt\pgfmathresult
    \pgfmathparse{\ZWidth  / 1pt}\let\Wpt\pgfmathresult
    \pgfmathparse{\Hpt / tan(\ZAngle)}\let\DXpt\pgfmathresult
    \pgfmathparse{\Ipt + \Wpt + 2.0*\DXpt}\let\Totalpt\pgfmathresult
    \pgfarrowssettipend{0pt}
    \pgfarrowssetbackend{-\Totalpt pt}
    \pgfarrowssetlineend{-\Totalpt pt}
    \pgfarrowshullpoint{0pt}{0pt}
    \pgfarrowshullpoint{-\Ipt pt - \DXpt pt}{-\Hpt pt}
    \pgfarrowshullpoint{-\Ipt pt - \Wpt pt - \DXpt pt}{\Hpt pt}
    \pgfarrowshullpoint{-\Totalpt pt}{0pt}
  },
  drawing code = {
    \pgfmathparse{\ZGap   / 1pt}\let\Ipt\pgfmathresult
    \pgfmathparse{\ZHeight / 1pt}\let\Hpt\pgfmathresult
    \pgfmathparse{\ZWidth  / 1pt}\let\Wpt\pgfmathresult
    \pgfmathparse{\Hpt / tan(\ZAngle)}\let\DXpt\pgfmathresult
    \pgfmathparse{\Ipt + \Wpt + 2.0*\DXpt}\let\Totalpt\pgfmathresult
    \pgfmathparse{0.5 * \pgflinewidth / 1pt}\let\HLWpt\pgfmathresult
    \pgfpathmoveto{\pgfpoint{-\Totalpt pt - \HLWpt pt}{0pt}}%
    \pgfpathlineto{\pgfpoint{-\Wpt pt - 2.0*\DXpt pt - \Ipt pt}{0pt}}%
    \pgfpathlineto{\pgfpoint{-\Wpt pt - \DXpt pt - \Ipt pt}{\Hpt pt}}%
    \pgfpathlineto{\pgfpoint{-\DXpt pt - \Ipt pt}{-\Hpt pt}}%
    \pgfpathlineto{\pgfpoint{-\Ipt pt}{0pt}}%
    \pgfpathlineto{\pgfpoint{\HLWpt pt}{0pt}}%
    \pgfusepathqstroke
  },
  defaults = { gap=0pt, height=10pt, angle=70, width=12pt },
}
